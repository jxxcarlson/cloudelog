# cloudelog — example environment configuration.
#
# Copy this to `.env` at the project root and edit for your machine.
# Scripts under `scripts/` auto-load `.env`.
#
# Local dev: defaults are fine; you can probably skip the .env entirely.
# Shared droplet (alongside greppit on 8086): pick distinct ports here.


# --- Database ---

# Local dev (libpq URL form, works everywhere):
DATABASE_URL=postgres://localhost/cloudelog_dev?sslmode=disable

# Production example (set on your droplet, not locally):
# DATABASE_URL=postgres://cloudelog:STRONG-PASS@localhost/cloudelog_prod


# --- Ports ---

# Dev default is 8081 (backend) / 8011 (frontend). On the shared droplet
# with greppit we use 8087 for cloudelog's backend (8086 is greppit).
# PORT is read by the backend directly.

# PORT=8087


# --- JWT ---

# Must be >= 32 bytes in production (HS256 requirement).
# Generate with: openssl rand -base64 48
# JWT_SECRET=change-me-to-a-long-random-string-in-production
# JWT_EXPIRY_DAYS=7


# --- Cookie security (production override) ---

# Set to "true" in production (HTTPS). Leaving unset / "false" keeps dev
# behavior (cookies work over plain HTTP on localhost).
# See deploy/README.md Phase 0 for the backend code change this depends on.
# COOKIE_SECURE=true


# --- CORS allowed origins (production override) ---

# Comma-separated list of origins the browser may use. Defaults to the dev
# frontend `http://localhost:8011` when unset. Set to the production origin
# (same host as nginx serves) so browser POSTs don't get rejected with a
# 400 "Unsupported origin".
# CORS_ALLOWED_ORIGINS=https://cloudelog.app


# --- db-fetch-dump.sh (pull dumps from the production host) ---

# CLOUDELOG_PROD_HOST=root@161.35.125.40
# CLOUDELOG_PROD_BACKUP_DIR=/root/cloudelog/backups
